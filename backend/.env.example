BACKEND=claude

# Claude — uses the local `claude` CLI (no API key needed if Claude Code is installed)
CLAUDE_MODEL=sonnet

# Ollama — local model runner
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# Devin — CLI (no key needed if `devin` is on PATH) or API key fallback
DEVIN_API_KEY=
DEVIN_BASE_URL=https://api.cognition.ai/v1
DEVIN_MODEL=devin
